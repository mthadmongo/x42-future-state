# Copy to .env and fill in real values. NEVER commit .env.
# (.env is git-ignored; only this .example template is tracked.)

# MongoDB Atlas connection string
MONGODB_URI=
MONGODB_DB=x42_agent

# Grove LLM gateway (OpenAI Responses API)
GROVE_API_KEY=
GROVE_BASE_URL=https://grove-gateway-prod.azure-api.net/grove-foundry-prod/openai/v1
GROVE_MODEL=gpt-5.5

# Voyage embeddings via the Atlas Embedding API (model API key from Atlas → AI Models)
VOYAGE_API_KEY=
VOYAGE_BASE_URL=https://ai.mongodb.com/v1
VOYAGE_MODEL=voyage-4-large
VOYAGE_DIMENSIONS=1024

# Agent config
INTENT_MODE=llm            # "llm" | "router"
CACHE_SIMILARITY_THRESHOLD=0.90
ROUTER_CONFIDENCE_THRESHOLD=0.80
MEMORY_TOP_K=5
MEMORY_DEDUPE_THRESHOLD=0.92
